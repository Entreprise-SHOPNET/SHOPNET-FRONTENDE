

{
  "expo": {
    "name": "SHOPNET",
    "slug": "shopnettest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,

    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shopai.app"
    },

    "android": {
      "package": "com.shopai.test",

      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },

      "permissions": ["POST_NOTIFICATIONS"],

      "notification": {
        "icon": "./assets/images/notification-icon.png",
        "color": "#4CB050"
      }
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      "expo-build-properties"
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f0e964ca-ce24-40ca-ada6-666e86e898f6"
      }
    },

    "owner": "shopnet_test"
  }
}
